{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://calendar-tool.local/schemas/extraction",
  "$defs": {
    "EventDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "date",
        "startTime",
        "endTime",
        "timezone",
        "location",
        "notes",
        "guests",
        "missingStartTime"
      ],
      "properties": {
        "title": { "type": "string" },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "startTime": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "string",
              "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
            }
          ]
        },
        "endTime": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "string",
              "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
            }
          ]
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        },
        "location": { "type": "string" },
        "notes": { "type": "string" },
        "guests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missingStartTime": { "type": "boolean" }
      }
    },
    "ExtractionWarning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "code", "message"],
      "properties": {
        "field": {
          "type": "string",
          "enum": [
            "general",
            "title",
            "date",
            "startTime",
            "endTime",
            "timezone",
            "location",
            "notes",
            "guests",
            "missingStartTime"
          ]
        },
        "code": {
          "type": "string",
          "enum": [
            "INFERRED_DATE",
            "DEFAULT_DURATION",
            "MISSING_START_TIME",
            "LOW_CONFIDENCE",
            "MULTIPLE_POSSIBLE_TIMES"
          ]
        },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "ExtractEventRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "timezone", "currentDate"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        },
        "currentDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "locale": { "type": "string", "minLength": 1 }
      }
    },
    "ExtractEventResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["draft", "warnings"],
      "properties": {
        "draft": { "$ref": "#/$defs/EventDraft" },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/ExtractionWarning" }
        }
      }
    },
    "ExtractEventError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error"],
      "properties": {
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": {
              "type": "string",
              "enum": [
                "EMPTY_INPUT",
                "LLM_EXTRACTION_FAILED",
                "INVALID_MODEL_OUTPUT",
                "INVALID_REQUEST",
                "RATE_LIMITED",
                "UNKNOWN",
                "NOT_IMPLEMENTED"
              ]
            },
            "message": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
